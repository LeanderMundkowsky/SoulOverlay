{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Tauri Dev",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@tauri-apps/cli/tauri.js",
      "args": ["dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_LOG": "debug"
      }
    },
    {
      "name": "Rust: Attach to Tauri",
      "type": "lldb",
      "request": "attach",
      "program": "${workspaceFolder}/src-tauri/target/debug/soul-overlay.exe",
      "sourceLanguages": ["rust"]
    },
    {
      "name": "Frontend (Vite)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:1420",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Tauri Dev + Rust",
      "configurations": ["Tauri Dev", "Rust: Attach to Tauri"],
      "stopAll": true
    }
  ]
}
