{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Tauri Dev",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@tauri-apps/cli/tauri.js",
      "args": [
        "dev"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_LOG": "debug"
      }
    },
    {
      "name": "Tauri Build",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@tauri-apps/cli/tauri.js",
      "args": [
        "build"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
