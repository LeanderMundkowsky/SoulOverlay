{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vue-tsc",
      "type": "shell",
      "command": "npx",
      "args": [
        "vue-tsc",
        "--noEmit"
      ],
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "cargo-check",
      "type": "shell",
      "command": "cargo",
      "args": [
        "check",
        "--all-targets",
        "--workspace"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "group": "build",
      "problemMatcher": [
        "$rustc"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "type-check-all",
      "dependsOn": [
        "vue-tsc",
        "cargo-check"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "tauri-dev",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "tauri",
        "dev"
      ],
      "isBackground": true,
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "tauri-build",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "tauri",
        "build"
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
