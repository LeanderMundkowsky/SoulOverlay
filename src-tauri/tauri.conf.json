{
  "$schema": "https://raw.githubusercontent.com/niclas-nicklaus/tauri-schema/2.x/schema.json",
  "productName": "SoulOverlay",
  "version": "0.6.3",
  "identifier": "dev.souloverlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
  "windows": [
    {
      "label": "overlay",
      "title": "SoulOverlay",
      "transparent": true,
      "decorations": false,
      "alwaysOnTop": true,
      "maximized": true,
      "fullscreen": false,
      "resizable": true,
      "visible": false
    }
  ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzM0QyNkFDOUMwMEUyMEQKUldRTjRnQ2NyQ1k5OHhRSlpib21ieTFVcE9UbkRDd3hTQVJuMVNHamNQRGV0SEQzM3VOYjdWU1gK",
      "endpoints": [
        "https://github.com/Soul-Returns/SoulOverlay/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
